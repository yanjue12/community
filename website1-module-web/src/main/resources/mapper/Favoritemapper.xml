<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fzg.mapper.Favoritemapper">

    <select id="queryFavoriteByUserBatch" resultType="java.lang.Long">
      select target_id from favorite
      where user_id = #{userId}
      and status = '1'
      and target_id in
      <foreach item="item" index="index" collection="articleIds" open="(" separator="," close=")">
        #{item}
      </foreach>
    </select>

</mapper>