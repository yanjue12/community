<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fzg.mapper.UserMapper">


    <select id="selectByCondition" resultType="com.fzg.model.User">
        select * from user
        <where>
            <if test="condition != null and condition != ''">
                (username = #{condition}) or email = #{condition}
            </if>
        </where>

    </select>
</mapper>