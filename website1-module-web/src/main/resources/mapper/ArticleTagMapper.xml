<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fzg.mapper.ArticleTagMapper">

    <select id="queryHotTags" resultType="com.fzg.model.ArticleTag">
        SELECT * FROM article_tag ORDER BY article_count DESC LIMIT 10
    </select>
</mapper>